{
  "name": "zreo-password",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "description": "Personal Password Vault desktop framework",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.zreo.password",
    "productName": "小〇密码",
    "directories": {
      "output": "dist"
    },
    "files": [
      "app.js",
      "index.html",
      "styles.css",
      "electron/**/*",
      "README.md",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "devDependencies": {
    "electron": "^36.2.0",
    "electron-builder": "^26.0.12"
  }
}
